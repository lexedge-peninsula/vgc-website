---
import "../styles/global.css";
import Seo from "../components/Seo.astro";
import SchemaLocalBusiness from "../components/SchemaLocalBusiness.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const {
  title = "Escribana Victoria García Casuriaga | Punta del Este",
  description = "Seguridad jurídica estratégica, con atención directa en operaciones inmobiliarias y corporativas en Punta del Este.",

  // SEO (opcionales)
  canonical,
  ogImage = "/og.jpg",
  noindex = false,
  lang = "es",
  locale = "es_UY",
  themeColor = "#0B1F3B",
} = Astro.props;

const canonicalUrl = canonical ?? Astro.url.toString();
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <Seo
      title={title}
      description={description}
      canonical={canonicalUrl}
      ogImage={ogImage}
      noindex={noindex}
      lang={lang}
      locale={locale}
      themeColor={themeColor}
    />
    <SchemaLocalBusiness />
  </head>

  <body class="min-h-screen flex flex-col">
    <Header />

    <!-- sin container para permitir secciones full-bleed -->
    <main class="flex-1">
      <slot />
    </main>

    <Footer />
  </body>
</html>