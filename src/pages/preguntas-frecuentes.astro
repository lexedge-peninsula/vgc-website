---
import BaseLayout from "../layouts/BaseLayout.astro";
import SchemaFAQ from "../components/SchemaFAQ.astro";

const faqs = [
  {
    q: "¿Puede un extranjero comprar propiedad en Uruguay?",
    a: "Sí. Un extranjero puede comprar inmuebles en Uruguay. La escribanía acompaña la operación, verifica títulos y coordina documentación y firma para garantizar seguridad jurídica.",
  },
  {
    q: "¿Cuánto demora una compraventa en Punta del Este?",
    a: "Depende de la situación registral, documentación y forma de pago. En general, tras reunir documentación y realizar estudio de títulos, se coordina firma y posteriores inscripciones.",
  },
  {
    q: "¿Qué gastos notariales existen en una compraventa?",
    a: "Existen costos notariales y tributos asociados a la operación (según el caso). Se informa un estimado claro antes de avanzar, para evitar sorpresas.",
  },
  {
    q: "¿Conviene comprar a título personal o mediante sociedad?",
    a: "Depende del objetivo patrimonial, fiscal y sucesorio. Se evalúa el caso y se recomienda una estructura simple y segura para cada cliente.",
  },
  {
    q: "¿Qué documentación se necesita para una compraventa?",
    a: "Varía según el inmueble y las partes. Generalmente se requieren datos de identificación, antecedentes del bien y documentación registral. Se arma un checklist al inicio para avanzar con eficiencia.",
  },
  {
    q: "¿Pueden firmar a distancia si estoy en el exterior?",
    a: "En muchos casos sí, mediante poder o coordinaciones específicas. Se analiza el caso y se propone el mecanismo más seguro y práctico.",
  },
];
---

<BaseLayout
  title="Preguntas frecuentes | Escribanía en Punta del Este"
  description="Respuestas claras sobre compraventas, sociedades, poderes y operaciones para clientes locales e internacionales en Punta del Este y Maldonado."
  canonical="https://vgc.uy/preguntas-frecuentes"
  ogImage="/og.jpg"
>
  <!-- Schema FAQ (solo en esta página) -->
  <SchemaFAQ faqs={faqs} />

  <section class="bg-[#0B1F3B] text-white border-b border-white/10">
    <div class="container py-16 md:py-20">
      <p class="text-sm uppercase tracking-widest text-white/70">
        Información clara · Punta del Este / Maldonado
      </p>

      <h1 class="mt-6 text-4xl md:text-5xl font-semibold leading-tight">
        Preguntas frecuentes
      </h1>

      <p class="mt-4 max-w-2xl text-white/80">
        Respuestas breves y prácticas para tomar decisiones con seguridad jurídica.
        Si tu caso requiere análisis, coordinamos una consulta.
      </p>

      <p class="mt-4 text-sm text-white/70">
        Temas habituales: compraventas, estudio de títulos, poderes, estructuras societarias.
      </p>

      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <a
          class="rounded-full bg-white text-[#0B1F3B] px-6 py-3 text-sm font-semibold no-underline hover:opacity-95"
          href="/contacto"
        >
          Solicitar consulta
        </a>
        <a
          class="rounded-full border border-white/25 px-6 py-3 text-sm no-underline hover:bg-white/10"
          href="/servicios/inmobiliario"
        >
          Ver servicios inmobiliarios
        </a>
      </div>
    </div>
  </section>

  <section class="container py-12 md:py-14">
    <div class="max-w-3xl">
      <h2 class="text-2xl md:text-3xl font-semibold tracking-tight text-[#0B1F3B]">
        Consultas comunes
      </h2>
      <p class="mt-3 text-black/70">
        Cada operación tiene matices. Estas respuestas orientan, pero la recomendación final siempre
        depende del caso concreto.
      </p>
    </div>

    <div class="mt-10 grid gap-4 md:gap-5">
      {faqs.map((f) => (
        <details class="group rounded-2xl border border-black/10 bg-white p-6 shadow-sm">
          <summary class="cursor-pointer list-none font-semibold text-[#0B1F3B] flex items-start justify-between gap-4">
            <span>{f.q}</span>
            <span class="text-black/40 group-open:rotate-45 transition-transform select-none">+</span>
          </summary>
          <div class="mt-3 text-black/75 leading-relaxed">{f.a}</div>
        </details>
      ))}
    </div>

    <div class="mt-12 rounded-2xl bg-black/5 p-8 border border-black/10">
      <h3 class="text-xl font-semibold text-[#0B1F3B]">
        ¿Tu consulta es específica o requiere revisión de documentación?
      </h3>
      <p class="mt-2 text-black/70 max-w-2xl">
        Coordinamos una consulta breve para entender el caso, definir próximos pasos y estimar tiempos.
      </p>
      <div class="mt-6 flex flex-col gap-3 sm:flex-row">
        <a
          class="rounded-full bg-[#0B1F3B] px-6 py-3 text-white text-sm font-semibold no-underline hover:opacity-90"
          href="/contacto"
        >
          Coordinar consulta
        </a>
        <a
          class="rounded-full border border-black/15 px-6 py-3 text-sm no-underline hover:bg-black/5"
          href="/servicios/corporativo"
        >
          Ver servicios corporativos
        </a>
      </div>
    </div>
  </section>
</BaseLayout>