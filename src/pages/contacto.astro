---
import BaseLayout from "../layouts/BaseLayout.astro";

const WHATSAPP_NUMBER_INTL = "59892217153";
const PHONE_DISPLAY = "+598 92 217 153";
const EMAIL = "info@vgc.uy"; // si no tenés email aún, dejalo así temporal o cambialo
const ADDRESS_LINE = "El Mesana local 2 en PB, Edificio Linton Village — Punta del Este";
const POSTAL_CODE = "20100";
const LINKEDIN_URL = "https://www.linkedin.com/in/vgcescribania/";

const HOURS = "Lunes a Viernes · 09:00–18:00";

// Form (si aún no lo configuraste, dejalo y después lo cambiamos)
const FORM_ACTION = "https://formspree.io/f/XXXXXXX";

// Mapa embed (pro y elegante): pegá el iframe URL de Google Maps cuando lo tengas.
// Mientras tanto dejo un placeholder “realista” vacío para que no rompa.
const MAP_EMBED_URL =
  "https://www.google.com/maps?q=Edificio%20Linton%20Village%20Punta%20del%20Este&output=embed";

const whatsappLink = `https://wa.me/${WHATSAPP_NUMBER_INTL}?text=${encodeURIComponent(
  "Hola, quiero coordinar una consulta. Mi consulta es:"
)}`;
const mailtoLink = `mailto:${EMAIL}?subject=${encodeURIComponent(
  "Consulta - Escribanía Victoria García Casuriaga"
)}`;
---

<BaseLayout
  title="Contacto | Escribana en Punta del Este"
  description="Coordiná una consulta con la Escribana Victoria García Casuriaga. Atención directa, criterio preventivo y coordinación ágil en Punta del Este y Maldonado."
>
  <!-- HERO -->
  <section class="relative overflow-hidden bg-[#0B1F3B] text-white border-b border-white/10">
    <div class="pointer-events-none absolute inset-0 opacity-30">
      <div class="absolute -top-40 -right-40 h-[520px] w-[520px] rounded-full bg-white/10 blur-3xl"></div>
      <div class="absolute -bottom-56 -left-56 h-[520px] w-[520px] rounded-full bg-white/5 blur-3xl"></div>
    </div>

    <div class="container relative py-16 md:py-20">
      <p class="text-sm uppercase tracking-widest text-white/70">
        Contacto · Punta del Este / Maldonado
      </p>

      <h1 class="mt-6 text-4xl md:text-6xl font-semibold leading-tight">
        Coordinemos una consulta
        <span class="block text-white/90">con claridad y agilidad.</span>
      </h1>

      <p class="mt-6 max-w-2xl text-lg text-white/80">
        Podés escribir por WhatsApp, enviar un correo o completar el formulario. Respondemos con atención directa y
        enfoque preventivo para avanzar con seguridad.
      </p>

      <div class="mt-10 flex flex-col gap-3 sm:flex-row">
        <a
          class="rounded-full bg-white text-[#0B1F3B] px-6 py-3 text-sm font-semibold no-underline hover:opacity-95"
          href={whatsappLink}
          target="_blank"
          rel="noopener noreferrer"
        >
          WhatsApp directo
        </a>
        <a
          class="rounded-full border border-white/25 px-6 py-3 text-sm no-underline hover:bg-white/10"
          href={mailtoLink}
        >
          Enviar email
        </a>
        <a
          class="rounded-full border border-white/25 px-6 py-3 text-sm no-underline hover:bg-white/10"
          href={LINKEDIN_URL}
          target="_blank"
          rel="noopener noreferrer"
        >
          LinkedIn
        </a>
      </div>
    </div>
  </section>

  <!-- CONTENIDO -->
  <section class="container py-12 md:py-14">
    <div class="grid gap-8 md:grid-cols-2">
      <!-- Columna izquierda: Datos + mapa -->
      <div>
        <h2 class="text-2xl md:text-3xl font-semibold tracking-tight text-[#0B1F3B]">
          Información de contacto
        </h2>
        <p class="mt-3 text-black/70">
          Para agilizar, contanos el tipo de operación y el estado actual. Si hay fecha tentativa, urgencia o intervención
          de banco/inmobiliaria, mejor aún.
        </p>

        <div class="mt-8 grid gap-4">
          <div class="rounded-2xl border border-black/10 bg-white p-6 shadow-sm">
            <div class="text-xs font-semibold text-black/50">WHATSAPP</div>
            <a
              class="mt-2 inline-block text-lg font-semibold text-[#0B1F3B] no-underline hover:underline"
              href={whatsappLink}
              target="_blank"
              rel="noopener noreferrer"
            >
              {PHONE_DISPLAY}
            </a>
            <p class="mt-2 text-black/70 text-sm">
              Canal más ágil para coordinación directa.
            </p>
          </div>

          <div class="rounded-2xl border border-black/10 bg-white p-6 shadow-sm">
            <div class="text-xs font-semibold text-black/50">EMAIL</div>
            <a class="mt-2 inline-block text-lg font-semibold text-[#0B1F3B] no-underline hover:underline" href={mailtoLink}>
              {EMAIL}
            </a>
            <p class="mt-2 text-black/70 text-sm">
              Ideal para adjuntar documentación o describir el caso con detalle.
            </p>
          </div>

          <div class="rounded-2xl border border-black/10 bg-white p-6 shadow-sm">
            <div class="text-xs font-semibold text-black/50">UBICACIÓN</div>
            <div class="mt-2 text-lg font-semibold text-[#0B1F3B]">{ADDRESS_LINE}</div>
            <p class="mt-2 text-black/70 text-sm">
              Código postal: {POSTAL_CODE} · Horario: {HOURS}
            </p>
          </div>

          <div class="rounded-2xl border border-black/10 bg-black/5 p-6">
            <h3 class="text-lg font-semibold text-[#0B1F3B]">Antes de coordinar</h3>
            <ul class="mt-3 grid gap-2 text-black/80 text-sm">
              <li>• Tipo de operación (compraventa, sociedad, poder, etc.)</li>
              <li>• Si existe fecha tentativa o urgencia</li>
              <li>• Si hay banco / inmobiliaria / terceros involucrados</li>
              <li>• Documentación disponible (si aplica)</li>
            </ul>
          </div>
        </div>

        <!-- MAPA (pro y elegante) -->
        <div class="mt-8 rounded-2xl overflow-hidden border border-black/10 bg-white shadow-sm">
          <div class="flex items-center justify-between border-b border-black/10 px-6 py-4">
            <div>
              <div class="text-sm font-semibold text-[#0B1F3B]">Ubicación</div>
              <div class="text-xs text-black/60">Edificio Linton Village · Punta del Este</div>
            </div>
            <a
              class="text-sm font-semibold text-[#0B1F3B] no-underline hover:underline"
              href="https://www.google.com/maps/search/?api=1&query=Edificio%20Linton%20Village%20Punta%20del%20Este"
              target="_blank"
              rel="noopener noreferrer"
            >
              Abrir en Google Maps →
            </a>
          </div>

          <iframe
            src={MAP_EMBED_URL}
            width="100%"
            height="360"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Mapa - Escribanía Victoria García Casuriaga"
          ></iframe>
        </div>
      </div>

      <!-- Columna derecha: Formulario -->
      <div>
        <div class="rounded-2xl border border-black/10 bg-white p-8 shadow-sm">
          <h2 class="text-2xl font-semibold tracking-tight text-[#0B1F3B]">
            Formulario de consulta
          </h2>
          <p class="mt-2 text-black/70">
            Respuesta breve y clara. Si tu caso requiere análisis documental, te indicamos próximos pasos.
          </p>

          <form class="mt-8 grid gap-4" method="post" action={FORM_ACTION}>
            <div class="grid gap-4 md:grid-cols-2">
              <label class="grid gap-2">
                <span class="text-sm font-semibold text-black/70">Nombre</span>
                <input
                  class="rounded-xl border border-black/15 bg-white px-4 py-3 text-sm outline-none focus:ring-4 focus:ring-black/10"
                  name="nombre"
                  required
                  autocomplete="name"
                  placeholder="Tu nombre"
                />
              </label>

              <label class="grid gap-2">
                <span class="text-sm font-semibold text-black/70">Teléfono / WhatsApp</span>
                <input
                  class="rounded-xl border border-black/15 bg-white px-4 py-3 text-sm outline-none focus:ring-4 focus:ring-black/10"
                  name="telefono"
                  autocomplete="tel"
                  placeholder="+598..."
                />
              </label>
            </div>

            <label class="grid gap-2">
              <span class="text-sm font-semibold text-black/70">Email</span>
              <input
                class="rounded-xl border border-black/15 bg-white px-4 py-3 text-sm outline-none focus:ring-4 focus:ring-black/10"
                name="email"
                type="email"
                required
                autocomplete="email"
                placeholder="tu@email.com"
              />
            </label>

            <label class="grid gap-2">
              <span class="text-sm font-semibold text-black/70">Tipo de consulta</span>
              <select
                class="rounded-xl border border-black/15 bg-white px-4 py-3 text-sm outline-none focus:ring-4 focus:ring-black/10"
                name="tipo"
                required
              >
                <option value="" selected disabled>Seleccionar…</option>
                <option>Operación inmobiliaria (compraventa / promesa / hipoteca)</option>
                <option>Estructuración corporativa (sociedades / actas / poderes)</option>
                <option>Poderes / certificaciones</option>
                <option>Cliente internacional</option>
                <option>Otro</option>
              </select>
            </label>

            <label class="grid gap-2">
              <span class="text-sm font-semibold text-black/70">Mensaje</span>
              <textarea
                class="min-h-[140px] rounded-xl border border-black/15 bg-white px-4 py-3 text-sm outline-none focus:ring-4 focus:ring-black/10"
                name="mensaje"
                required
                placeholder="Contanos brevemente tu situación y qué necesitás."
              ></textarea>
            </label>

            <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
              <button
                class="rounded-full bg-[#0B1F3B] px-6 py-3 text-white text-sm font-semibold hover:opacity-90"
                type="submit"
              >
                Enviar consulta
              </button>

              <p class="text-xs text-black/60">
                Al enviar, aceptás ser contactado para coordinar la consulta.
              </p>
            </div>
          </form>
        </div>

        <div class="mt-6 rounded-2xl bg-black/5 p-6 border border-black/10">
          <h3 class="text-lg font-semibold text-[#0B1F3B]">¿Preferís WhatsApp?</h3>
          <p class="mt-2 text-black/70 text-sm">
            Si tu consulta es breve o necesitás coordinar rápido, el canal más ágil es WhatsApp.
          </p>
          <div class="mt-4">
            <a
              class="inline-flex rounded-full bg-white px-6 py-3 text-sm font-semibold text-[#0B1F3B] no-underline border border-black/10 hover:bg-black/5"
              href={whatsappLink}
              target="_blank"
              rel="noopener noreferrer"
            >
              Abrir WhatsApp
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>