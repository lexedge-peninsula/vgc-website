---
/**
 * Schema Service (por página de servicio).
 * Usalo dentro de cada landing para declarar el servicio a Google.
 */

const props = Astro.props ?? {};

const {
  siteUrl = "https://vgc.uy",
  providerName = "Escribana Victoria García Casuriaga",

  // Obligatorios por página
  name,
  description,

  // Opcionales recomendados
  url = null, // ej: "https://vgc.uy/servicios/inmobiliario"
  serviceType = null, // ej: "Operaciones inmobiliarias"
  area = ["Punta del Este", "Maldonado", "Uruguay"],
} = props;

// Normaliza areaServed: Country para Uruguay, AdministrativeArea para el resto
const areaServed = (area ?? []).map((n) => {
  const isUY = String(n).toLowerCase() === "uruguay" || String(n).toUpperCase() === "UY";
  return isUY ? { "@type": "Country", name: "Uruguay" } : { "@type": "AdministrativeArea", name: n };
});

const data = {
  "@context": "https://schema.org",
  "@type": "Service",
  name,
  description,

  ...(serviceType ? { serviceType } : {}),
  ...(url ? { url } : {}),

  provider: {
    "@type": ["Notary", "LegalService"],
    name: providerName,
    url: siteUrl,
  },

  ...(areaServed.length ? { areaServed } : {}),
};
---

<!-- IMPORTANTE: set:html evita que se imprima como texto literal -->
<script type="application/ld+json" set:html={JSON.stringify(data)} />