---
/**
 * Schema Local para SEO Local (Google / Maps).
 * Tip: completá phone y dirección real. Si tenés coordenadas (lat/lng), mejor.
 */

const props = Astro.props ?? {};

const {
  siteUrl = "https://vgc.uy",
  name = "Escribana Victoria García Casuriaga",
  description =
    "Escribana boutique especializada en operaciones inmobiliarias y estructuración corporativa en Punta del Este, con asesoramiento ágil, personalizado y adaptado a clientes locales e internacionales.",

  // Contacto (ideal: completarlos)
  phone = "+598XXXXXXXX",
  email = null,

  // Dirección (ideal: completarla)
  streetAddress = "Dirección (completar)",
  addressLocality = "Punta del Este",
  addressRegion = "Maldonado",
  postalCode = "20XXX",
  addressCountry = "UY",

  // Coordenadas (recomendado)
  latitude = null, // e.g. -34.96
  longitude = null, // e.g. -54.95

  // Horarios (formato simple)
  openingHours = [
    // "Mo-Fr 09:00-18:00"
  ],

  // Redes (si aplica)
  sameAs = [
    // "https://www.linkedin.com/in/...",
    // "https://www.instagram.com/..."
  ],

  // Imagen
  image = `${siteUrl}/og.jpg`,

  // Logo (si querés, podés usar el lockup o el favicon grande)
  logo = `${siteUrl}/logo-lockup-color.png`,
} = props;

const hasGeo = typeof latitude === "number" && typeof longitude === "number";

// NAP consistente
const address = {
  "@type": "PostalAddress",
  streetAddress,
  addressLocality,
  addressRegion,
  postalCode,
  addressCountry,
};

const data = {
  "@context": "https://schema.org",

  // Más específico para escribanía:
  // Notary existe en schema.org y suele ser más preciso que LegalService.
  "@type": ["Notary", "LegalService", "LocalBusiness"],

  name,
  description,
  url: siteUrl,
  image,
  logo,
  telephone: phone,

  ...(email ? { email } : {}),

  address,

  // Cobertura geográfica
  areaServed: [
    { "@type": "AdministrativeArea", name: "Punta del Este" },
    { "@type": "AdministrativeArea", name: "Maldonado" },
    { "@type": "Country", name: "Uruguay" },
  ],

  ...(openingHours?.length ? { openingHours } : {}),
  ...(sameAs?.length ? { sameAs } : {}),

  ...(hasGeo
    ? {
        geo: {
          "@type": "GeoCoordinates",
          latitude,
          longitude,
        },
      }
    : {}),
};
---

<!-- IMPORTANTE: set:html evita que se imprima como texto literal -->
<script type="application/ld+json" set:html={JSON.stringify(data)} />