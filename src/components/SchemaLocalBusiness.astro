---
/**
 * Schema Local para SEO Local (Google / Maps).
 * Tip: si conseguís coordenadas (lat/lng), sumalas: mejora SEO local.
 */

const props = Astro.props ?? {};

const {
  siteUrl = "https://vgc.uy",
  name = "Escribana Victoria García Casuriaga",
  description =
    "Escribana boutique especializada en operaciones inmobiliarias y estructuración corporativa en Punta del Este, con asesoramiento ágil, personalizado y adaptado a clientes locales e internacionales.",

  // ✅ Contacto real (E.164)
  phone = "+59892217153",
  email = "victoria@vgc.uy",

  // ✅ Dirección real
  streetAddress = "El Mesana, local 2 (PB), Edificio Linton Village",
  addressLocality = "Punta del Este",
  addressRegion = "Maldonado",
  postalCode = "20100",
  addressCountry = "UY",

  // Coordenadas (opcional, recomendado)
  latitude = null, // ej: -34.96
  longitude = null, // ej: -54.95

  // Horarios (si los querés activar)
  openingHours = [
    // "Mo-Fr 09:00-18:00"
  ],

  // ✅ Redes (si aplica)
  sameAs = [
    "https://www.linkedin.com/in/vgcescribania/",
  ],

  // Imagen / logo
  image = `${siteUrl}/og.jpg`,
  logo = `${siteUrl}/logo-lockup-color.png`,
} = props;

const hasGeo = typeof latitude === "number" && typeof longitude === "number";

// NAP consistente
const address = {
  "@type": "PostalAddress",
  streetAddress,
  addressLocality,
  addressRegion,
  postalCode,
  addressCountry,
};

const data = {
  "@context": "https://schema.org",
  "@type": ["Notary", "LegalService", "LocalBusiness"],

  name,
  description,
  url: siteUrl,
  image,
  logo,

  telephone: phone,
  ...(email ? { email } : {}),

  address,

  areaServed: [
    { "@type": "AdministrativeArea", name: "Punta del Este" },
    { "@type": "AdministrativeArea", name: "Maldonado" },
    { "@type": "Country", name: "Uruguay" },
  ],

  ...(openingHours?.length ? { openingHours } : {}),
  ...(sameAs?.length ? { sameAs } : {}),

  ...(hasGeo
    ? {
        geo: {
          "@type": "GeoCoordinates",
          latitude,
          longitude,
        },
      }
    : {}),
};
---
<script type="application/ld+json" set:html={JSON.stringify(data)} />