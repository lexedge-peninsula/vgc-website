---
const nav = [
  { href: "/servicios/inmobiliario", label: "Inmobiliario" },
  { href: "/servicios/corporativo", label: "Corporativo" },
  { href: "/servicios/internacional", label: "Internacional" },
  { href: "/preguntas-frecuentes", label: "Preguntas frecuentes" },
  { href: "/sobre-mi", label: "Sobre mí" },
];

const cta = { href: "/contacto", label: "Agendar reunión" };
---

<header class="sticky top-0 z-50 border-b border-slate-200 bg-white/90 backdrop-blur supports-[backdrop-filter]:bg-white/80">
  <div class="container flex items-center justify-between py-6">

    <!-- LOGO -->
    <a
      href="/"
      class="flex items-center no-underline focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-[#C9A24A]/25 rounded-2xl"
      aria-label="Inicio — Victoria García Casuriaga"
    >
      <img
        src="/logo-vgc-navy.png"
        alt="Victoria García Casuriaga"
        class="h-12 md:h-14 w-auto transition-opacity duration-200 hover:opacity-90"
        loading="eager"
        decoding="async"
      />
    </a>

    <!-- NAV DESKTOP -->
    <nav class="hidden md:flex items-center gap-10" aria-label="Navegación principal">
      {nav.map((i) => (
        <a
          href={i.href}
          class="group relative text-sm tracking-wide text-slate-700 no-underline transition-colors duration-200 hover:text-[#0B1F3B] focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-[#C9A24A]/25 rounded-xl px-1 py-1"
        >
          {i.label}
          <!-- Subrayado elegante -->
          <span class="absolute left-0 -bottom-2 h-[2px] w-0 bg-[#C9A24A] transition-all duration-300 group-hover:w-full"></span>
        </a>
      ))}
    </nav>

    <!-- CTA DESKTOP -->
    <a
      href={cta.href}
      class="hidden md:inline-flex items-center justify-center rounded-full bg-[#0B1F3B] px-7 py-3 text-sm font-medium text-white no-underline shadow-sm hover:shadow-md hover:-translate-y-[1px] transition-all duration-200 focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-[#C9A24A]/25"
    >
      {cta.label}
    </a>

    <!-- MOBILE BUTTON -->
    <button
      type="button"
      class="md:hidden inline-flex items-center justify-center h-11 w-11 rounded-2xl text-[#0B1F3B] hover:bg-slate-50 transition focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-[#C9A24A]/25"
      onclick="
        const el = document.getElementById('mobile-menu');
        const isOpen = !el.classList.contains('hidden');
        el.classList.toggle('hidden');
        this.setAttribute('aria-expanded', String(!isOpen));
      "
      aria-label="Abrir menú"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>

  </div>

  <!-- MOBILE MENU -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-slate-200 bg-white">
    <div class="container py-6">
      <div class="rounded-3xl border border-slate-200 bg-white p-5 shadow-sm">

        <nav class="flex flex-col gap-1" aria-label="Navegación móvil">
          {nav.map((i) => (
            <a
              href={i.href}
              class="rounded-2xl px-4 py-3 text-base text-slate-700 no-underline hover:bg-slate-50 hover:text-[#0B1F3B] transition focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-[#C9A24A]/25"
            >
              {i.label}
            </a>
          ))}
        </nav>

        <a
          href={cta.href}
          class="mt-5 inline-flex w-full items-center justify-center rounded-full bg-[#0B1F3B] px-7 py-3 text-sm font-medium text-white no-underline hover:opacity-90 transition focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-[#C9A24A]/25"
        >
          {cta.label}
        </a>

        <p class="mt-4 text-xs text-slate-500 text-center">
          Atención directa · Coordinación remota · Clientes internacionales
        </p>

      </div>
    </div>
  </div>
</header>