---
const { faqs = [] } = Astro.props;

const data = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: {
      "@type": "Answer",
      text: f.a,
    },
  })),
};
---

{faqs?.length ? (
  <script type="application/ld+json">{JSON.stringify(data)}</script>
) : null}