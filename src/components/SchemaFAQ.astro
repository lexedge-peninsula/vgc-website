---
const { faqs = [] } = Astro.props;

const data = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: (faqs ?? [])
    .filter((f) => f?.q && f?.a)
    .map((f) => ({
      "@type": "Question",
      name: String(f.q),
      acceptedAnswer: {
        "@type": "Answer",
        text: String(f.a),
      },
    })),
};
---

{data.mainEntity.length ? (
  <script type="application/ld+json" set:html={JSON.stringify(data)} />
) : null}